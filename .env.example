# Copy this to .env and fill in your values

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Local SQLite (default) — Railway sets this automatically for PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///splitlah.db

# Default currency for new groups
DEFAULT_CURRENCY=SGD

# ExchangeRate-API key for 160+ currency support (free at exchangerate-api.com)
# Without this, falls back to frankfurter.app (~32 currencies only)
EXCHANGE_RATE_API_KEY=your_key_here
